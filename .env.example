# LiveFaces Backend Setup
# Copy this file to .env and replace placeholders with your real TEST/dev values.

NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
WEB_SUCCESS_URL=http://localhost:3000/success
WEB_CANCEL_URL=http://localhost:3000/cancel

# Stripe server-only values. NEVER expose these in Expo/mobile/frontend code.
STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_signing_secret

# Stripe publishable key is safe for client apps.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_test_publishable_key

# Stripe Price IDs from Stripe Dashboard > Products > Pricing
STRIPE_PRICE_MONTHLY=price_REPLACE_MONTHLY
STRIPE_PRICE_YEARLY=price_REPLACE_YEARLY

# Firebase Admin SDK service account values.
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key.
FIREBASE_PROJECT_ID=replace_with_project_id
FIREBASE_CLIENT_EMAIL=replace_with_client_email
FIREBASE_PRIVATE_KEY="replace_with_private_key_keep_newline_escapes"

# Local test helpers
EXPO_PUBLIC_MOCK_PREMIUM=false
